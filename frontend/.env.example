# Supabase ----------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://zjsngscwciwkdmrnvcwp.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6Inpqc25nc2N3Y2l3a2Rtcm52Y3dwIiwicm9sZSI6ImFub24iLCJpYXQiOjE3NjkzNzIzNTIsImV4cCI6MjA4NDk0ODM1Mn0.LMveWmmYyEJwamE4sBudrOkRcI29r8k7cGuC9lbh6BE
SUPABASE_SERVICE_ROLE_KEY=

# App URL (used for redirects, invites, OAuth callback fallback) ----
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Mapbox (donor map) ------------------------------------------------
NEXT_PUBLIC_MAPBOX_TOKEN=

# QuickBooks OAuth --------------------------------------------------
QB_CLIENT_ID=
QB_CLIENT_SECRET=
QB_REDIRECT_URI=
QB_ENVIRONMENT=sandbox

# Google OAuth (Gmail "send as") -----------------------------------
# 1. Create OAuth 2.0 Client ID (Web application) in Google Cloud Console
# 2. Add redirect URI: <app-url>/api/gmail/callback
# 3. Enable Gmail API + Google People API
# 4. Add scopes on consent screen: gmail.send + userinfo.email
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
# Optional — derived from request host if unset.
GOOGLE_OAUTH_REDIRECT_URI=

# AES-256-GCM key for encrypting Gmail tokens at rest.
# Generate with: openssl rand -base64 32
ENCRYPTION_KEY=

# Resend (system emails only — digest, password reset, notifications)
# User-initiated donor emails go through Gmail OAuth instead.
RESEND_API_KEY=

# AI providers ------------------------------------------------------
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Stripe ------------------------------------------------------------
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Per-plan price IDs from https://dashboard.stripe.com/products
# (one recurring monthly + one recurring annual price per tier).
# Required for the upgrade flow. Canonical amounts:
#   Starter  $49/mo or $468/yr ($39/mo) — env keys use the internal id ESSENTIALS
#   Growth   $99/mo or $948/yr ($79/mo)
#   Pro      $179/mo or $1,716/yr ($143/mo)
STRIPE_PRICE_ESSENTIALS_MONTHLY=
STRIPE_PRICE_GROWTH_MONTHLY=
STRIPE_PRICE_PRO_MONTHLY=
STRIPE_PRICE_ESSENTIALS_ANNUAL=
STRIPE_PRICE_GROWTH_ANNUAL=
STRIPE_PRICE_PRO_ANNUAL=

# Feature flags ------------------------------------------------------
# User-initiated email sending (compose dialog, bulk send, donor detail
# "Send Email" buttons). Set to "true" to enable. Keep "false" until
# Gmail OAuth is configured and the flow is validated.
# Both vars gate the feature; the server-side one prevents API misuse.
NEXT_PUBLIC_EMAIL_ENABLED=false
EMAIL_ENABLED=false
